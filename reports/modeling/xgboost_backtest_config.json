{
  "model_name": "xgboost_log_target_nested",
  "validation_strategy": "nested_chronological_validation",
  "outer_fold_count": 4,
  "forecast_horizon_days": 16,
  "inner_validation_days": 16,
  "training_window_days": 730,
  "maximum_estimators": 1500,
  "early_stopping_rounds": 75,
  "random_seed": 42,
  "shared_model_parameters": {
    "objective": "reg:squarederror",
    "eval_metric": "rmse",
    "learning_rate": 0.05,
    "max_depth": 8,
    "min_child_weight": 5,
    "subsample": 0.85,
    "colsample_bytree": 0.85,
    "reg_alpha": 0.05,
    "reg_lambda": 5.0,
    "tree_method": "hist",
    "max_bin": 256,
    "enable_categorical": true,
    "random_state": 42,
    "n_jobs": -1
  },
  "target_transformation": "log1p",
  "prediction_inverse_transformation": "clip(expm1(prediction), lower=0)",
  "outer_validation_used_for_model_selection": false
}